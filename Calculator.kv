<CalcButton@Button>:
    background_normal: ""
    background_color: 0.2, 0.2, 0.2, 1
    color: 1, 1, 1, 1
    font_size: 24
    on_press: app.on_button_press(self)

BoxLayout:
    orientation: "vertical"
    padding: 10
    spacing: 10
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    TextInput:
        id: display
        text: "0"
        font_size: 48
        readonly: True
        halign: "right"
        background_color: 0, 0, 0, 1
        foreground_color: 1, 1, 1, 1
        size_hint_y: 0.3

    GridLayout:
        cols: 4
        spacing: 10
        size_hint_y: 0.7

        CalcButton:
            text: "AC"
            background_color: 0.6, 0.6, 0.6, 1
        CalcButton:
            text: "+/-"
            background_color: 0.6, 0.6, 0.6, 1
        CalcButton:
            text: "%"
            background_color: 0.6, 0.6, 0.6, 1
        CalcButton:
            text: "÷"
            background_color: 1, 0.6, 0, 1

        CalcButton:
            text: "7"
        CalcButton:
            text: "8"
        CalcButton:
            text: "9"
        CalcButton:
            text: "×"
            background_color: 1, 0.6, 0, 1

        CalcButton:
            text: "4"
        CalcButton:
            text: "5"
        CalcButton:
            text: "6"
        CalcButton:
            text: "-"
            background_color: 1, 0.6, 0, 1

        CalcButton:
            text: "1"
        CalcButton:
            text: "2"
        CalcButton:
            text: "3"
        CalcButton:
            text: "+"
            background_color: 1, 0.6, 0, 1

        CalcButton:
            text: "0"
        CalcButton:
            text: "."
        CalcButton:
            text: "DEL"
            background_color: 0.6, 0.6, 0.6, 1
        CalcButton:
            text: "="
            background_color: 1, 0.6, 0, 1
